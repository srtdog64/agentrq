# App Configuration
ENV=production # development/production are the only options
PORT=80
AGENTRQ_BASE_URL=https://app.agentrq.com
AGENTRQ_DOMAIN=app.agentrq.com

# SSL Configuration (Production only)
AGENTRQ_SSL_ENABLED=false
AGENTRQ_SSL_CACHE_DIR=/_certs
AGENTRQ_SSL_LETSENCRYPT_EMAIL=
AGENTRQ_SSL_CLOUDFLARE_API_TOKEN=

# Database Configuration (SQLite)
AGENTRQ_SQLITE_ENABLED=true
AGENTRQ_SQLITE_DSN=./_storage/agentrq.db

# Database Configuration (PostgreSQL)
AGENTRQ_POSTGRES_ENABLED=false
AGENTRQ_POSTGRES_HOST=localhost
AGENTRQ_POSTGRES_USER=postgres
AGENTRQ_POSTGRES_PASSWORD=postgres
AGENTRQ_POSTGRES_DBNAME=agentrq
AGENTRQ_POSTGRES_PORT=5432

# Authentication
AGENTRQ_AUTH_JWT_SECRET=agentrq-secret-change-me
AGENTRQ_AUTH_ROOT_ACCESS_TOKEN=agentrq
AGENTRQ_AUTH_ROOT_LOGIN_ENABLED=false
AGENTRQ_AUTH_WORKSPACE_TOKEN_KEY=agentrq-token-key-change-me-32by

# Google OAuth2 (for login)
AGENTRQ_ACCOUNTS_OAUTH2_CLI_GOOGLE_CLIENT_ID=
AGENTRQ_ACCOUNTS_OAUTH2_CLI_GOOGLE_CLIENT_SECRET=

# GitHub OAuth2 (for login)
AGENTRQ_ACCOUNTS_OAUTH2_CLI_GITHUB_CLIENT_ID=
AGENTRQ_ACCOUNTS_OAUTH2_CLI_GITHUB_CLIENT_SECRET=

# SMTP Configuration
AGENTRQ_SMTP_ENABLED=true
AGENTRQ_SMTP_HOST=
AGENTRQ_SMTP_PORT=587
AGENTRQ_SMTP_USERNAME=
AGENTRQ_SMTP_PASSWORD=
AGENTRQ_SMTP_FROM="AgentRQ <no-reply@example.com>"

# Slack Multi-Tenant Integration
AGENTRQ_SLACK_ENABLED=false
AGENTRQ_SLACK_SIGNING_SECRET=
AGENTRQ_SLACK_APP_ID=
AGENTRQ_SLACK_CLIENT_ID=
AGENTRQ_SLACK_CLIENT_SECRET=

# Web Push Notifications (PWA)
# Generate VAPID keys with: npx web-push generate-vapid-keys
AGENTRQ_WEBPUSH_VAPID_PUBLIC_KEY=
AGENTRQ_WEBPUSH_VAPID_PRIVATE_KEY=
# Contact URI shown to push services (mailto: or https:)
AGENTRQ_WEBPUSH_SUBSCRIBER=mailto:hi@example.com
